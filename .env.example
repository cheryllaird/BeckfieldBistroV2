# Firebase configuration — copy to .env.local and fill in your values
# Get these from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Gemini API key — optional, used only by the test-gemini.ts smoke-test script.
# The app itself no longer uses a shared key: each user provides their own
# Gemini API key in Settings, so extraction usage/cost is billed to them.
# Get a free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Firebase service account JSON for server-side token verification
# Generate from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON content as a single-line string
FIREBASE_SERVICE_ACCOUNT=

# Secret key used to encrypt each user's Gemini API key at rest in Firestore
# (AES-256-GCM, server-side only). Must be a base64-encoded 32-byte value.
# Generate one with: openssl rand -base64 32
API_KEY_ENCRYPTION_SECRET=
